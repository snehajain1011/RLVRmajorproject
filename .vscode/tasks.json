{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Setup: install editable package",
      "type": "shell",
      "command": ".\\.conda\\python.exe -m pip install -e .[dev,benchmarks]",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PLAYWRIGHT_BROWSERS_PATH": "${workspaceFolder}\\.playwright",
          "NLTK_DATA": "${workspaceFolder}\\.nltk_data"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Setup: install Chromium",
      "type": "shell",
      "command": ".\\.conda\\python.exe -m playwright install chromium",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PLAYWRIGHT_BROWSERS_PATH": "${workspaceFolder}\\.playwright",
          "NLTK_DATA": "${workspaceFolder}\\.nltk_data"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Smoke: BrowserGym Social tasks",
      "type": "shell",
      "command": ".\\.conda\\python.exe scripts\\smoke_browsergym_social.py",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PLAYWRIGHT_BROWSERS_PATH": "${workspaceFolder}\\.playwright",
          "NLTK_DATA": "${workspaceFolder}\\.nltk_data"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "RLVR: train complex tasks",
      "type": "shell",
      "command": ".\\.conda\\python.exe scripts\\train_browsergym_rlvr.py --ollama-model qwen2.5:0.5b --model-no-images --model-steps 6 --tasks browsergym/social_rlvr.orders.priority_followup,browsergym/social_rlvr.schedule.design_review_shared_slot --out artifacts\\rlvr_training_complex\\learned_policy.json",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PLAYWRIGHT_BROWSERS_PATH": "${workspaceFolder}\\.playwright",
          "NLTK_DATA": "${workspaceFolder}\\.nltk_data"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "RLVR: eval complex before-after",
      "type": "shell",
      "command": ".\\.conda\\python.exe scripts\\evaluate_browsergym_rlvr.py --policies qwen,rlvr --ollama-model qwen2.5:0.5b --model-no-images --model-steps 6 --tasks browsergym/social_rlvr.orders.priority_followup,browsergym/social_rlvr.schedule.design_review_shared_slot --rlvr-policy artifacts\\rlvr_training_complex\\learned_policy.json --out artifacts\\eval_qwen_text_complex_rlvr",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PLAYWRIGHT_BROWSERS_PATH": "${workspaceFolder}\\.playwright",
          "NLTK_DATA": "${workspaceFolder}\\.nltk_data"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "RLVR: eval report before-after",
      "type": "shell",
      "command": ".\\.conda\\python.exe scripts\\evaluate_browsergym_rlvr.py --policies qwen,rlvr --ollama-model qwen2.5:0.5b --model-no-images --model-steps 4 --tasks browsergym/social_rlvr.report.extract_tracking_code --rlvr-policy artifacts\\rlvr_training_report\\learned_policy.json --out artifacts\\eval_qwen_text_report_rlvr",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PLAYWRIGHT_BROWSERS_PATH": "${workspaceFolder}\\.playwright",
          "NLTK_DATA": "${workspaceFolder}\\.nltk_data"
        }
      },
      "problemMatcher": []
    }
  ]
}
